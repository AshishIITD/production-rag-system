# ─────────────────────────────────────────────────────────
# .env.example — Copy this to .env and add your real values
# NEVER commit .env with real API keys to GitHub
# ─────────────────────────────────────────────────────────

# This project runs fully OFFLINE using local Ollama (llama3.1:8b)
# No API key is required for core functionality.

# Optional — only needed for cloud LLM (Gemini):
GOOGLE_API_KEY=your_google_api_key_here

# Optional — for LangGraph web search (Project 2 only):
TAVILY_API_KEY=your_tavily_api_key_here

# Optional — for fine-tuning experiment tracking (Project 3 only):
WANDB_API_KEY=your_wandb_api_key_here
HF_TOKEN=your_huggingface_token_here
